@startuml actividad_asignar_roles
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName Segoe UI
skinparam ActivityFontSize 12
skinparam activity {
  BackgroundColor #DCE9F5
  BorderColor #2E5A88
  DiamondBackgroundColor #FBF3D0
  DiamondBorderColor #B9A24B
  ArrowColor #34506B
}
title Diagrama de Actividades — Asignar roles a un usuario (SOLSGE)

|Administrador|
start
:Seleccionar un usuario;
|Sistema|
:Mostrar roles asignados y disponibles;
|Administrador|
:Marcar / desmarcar roles;
:Guardar;
|Sistema|
repeat :Tomar un cambio de rol;
  if (¿Rol agregado?) then (sí)
    :INSERT en EMPLEADOS_ROLES;
  else (quitado)
    :DELETE de EMPLEADOS_ROLES;
  endif
repeat while (¿más cambios?) is (sí)
->no;
:Recalcular acceso efectivo (unión de privilegios);
|Administrador|
:Roles actualizados;
stop

@enduml
