@startuml casos_uso_ventas
' ============================================================================
' SolSGE - Diagrama de Casos de Uso - Módulo Ventas (Presupuestos)
' ============================================================================
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName Segoe UI
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #DCE9F5
  BorderColor #2E5A88
  ArrowColor #34506B
}
skinparam actor {
  BackgroundColor #DCE9F5
  BorderColor #2E5A88
}
left to right direction

title Diagrama de Casos de Uso — Módulo Ventas (SOLSGE)

actor Vendedor as V
actor Supervisor as S

rectangle "Ventas (Presupuestos)" {
  usecase "Crear presupuesto" as UC1
  usecase "Aprobar presupuesto" as UC2
  usecase "Anular presupuesto" as UC3
}

V --> UC1
S --> UC2
V --> UC2
S --> UC3

note bottom of UC2
  El Supervisor aprueba; el Vendedor
  también puede aprobar previa
  confirmación del cliente.
end note

UC2 ..> UC1 : «sobre»\npresupuesto PENDIENTE
UC3 ..> UC1 : «sobre»\npresupuesto PENDIENTE/APROBADO

@enduml
