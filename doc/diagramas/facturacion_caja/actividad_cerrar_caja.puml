@startuml actividad_cerrar_caja
' ============================================================================
' SolSGE - Diagrama de Actividades - "Cerrar y arquear caja" (F17)
' Flujo real: P62 → P61 (monto declarado) → CERRAR_CAJA v3.
' ============================================================================
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName Segoe UI
skinparam ActivityFontSize 12
skinparam activity {
  BackgroundColor #DCE9F5
  BorderColor #2E5A88
  DiamondBackgroundColor #FBF3D0
  DiamondBorderColor #B9A24B
  ArrowColor #34506B
}

title Diagrama de Actividades — Cerrar y arquear caja (SOLSGE)

|Cajero|
start
:Abrir Estado de Caja (P62);
:Revisar saldo esperado por moneda\n(V_CAJA_SALDO) y movimientos;
:Presionar Cerrar → arqueo (P61);
:Contar el efectivo e ingresar el monto declarado;
:Confirmar cierre;

|Sistema|
:CERRAR_CAJA(id_caja, usuario);
if (¿Hay caja abierta?) then (no)
  :Error (-20940);
  stop
else (sí)
endif
:Marcar caja CERRADA (ESTADO='C', fecha/usuario);
repeat :Tomar una moneda;
  :MONTO_CIERRE = saldo esperado;
  :MONTO_DIFERENCIA = declarado − esperado;
repeat while (¿más monedas?) is (sí)
->no;
:Marcar los movimientos de la caja como cerrados;
:Generar documento de arqueo (P132);

|Cajero|
:Imprimir arqueo (con sobrante/faltante);
stop

@enduml
