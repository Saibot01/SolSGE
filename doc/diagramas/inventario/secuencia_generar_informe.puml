@startuml secuencia_generar_informe
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName Segoe UI
skinparam sequenceMessageAlign center
skinparam ParticipantFontSize 12
skinparam sequence {
  ArrowColor #34506B
  LifeLineBorderColor #7A93AB
  ParticipantBorderColor #2E5A88
  ParticipantBackgroundColor #DCE9F5
  ActorBorderColor #2E5A88
  ActorBackgroundColor #DCE9F5
}
title Diagrama de Secuencia — Generar informe de inventario (SOLSGE)

actor Gerente as G
participant "P143\nGenerador de Informe" as PG <<página>>
participant "FN_INFORME_\nINVENTARIO_HTML" as FN <<función>>
participant "Vistas V_INV_*\n(stock / rotación)" as V <<vista>>
participant "STOCK_PRODUCTO /\nMOVIMIENTOS_STOCK" as E <<entidad>>

G -> PG : elige filtros (sucursal, categoría, rango)
activate PG
PG -> FN : FN_INFORME_INVENTARIO_HTML(filtros)
activate FN
FN -> V : consulta valorización / niveles / rotación
activate V
V -> E : lee stock (snapshot) y movimientos (rango)
V --> FN : datos agregados
deactivate V
FN --> PG : HTML del informe (barras CSS, @media print)
deactivate FN
PG --> G : muestra / imprime el informe
deactivate PG

@enduml
