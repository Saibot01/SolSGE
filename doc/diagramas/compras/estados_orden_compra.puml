@startuml estados_orden_compra
!theme plain
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam DefaultFontName Segoe UI
skinparam state {
  BackgroundColor #DCE9F5
  BorderColor #2E5A88
  ArrowColor #34506B
  FontSize 13 }
title Diagrama de Estados — Orden de Compra (SOLSGE)

[*] --> Borrador : crear OC
state "Borrador\n(B)" as B
state "Pendiente\nrecepción (P)" as P
state "Completada\n(C)" as C
state "Rechazada\n(X)" as X
state "Anulada\n(A)" as A

B --> P : aprobar (Supervisor) / enviar al proveedor
B --> X : rechazar (Supervisor)
P --> C : recepción completa (Encargado de Depósito)\nentra stock
P --> A : anular
C --> [*]
X --> [*]
A --> [*]
@enduml
