@startuml er_compras
!theme plain
skinparam dpi 150
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 4
skinparam linetype ortho
skinparam DefaultFontName Segoe UI
skinparam entityFontSize 12
skinparam entityAttributeFontSize 10
skinparam entity {
  BackgroundColor #FFFFFF
  BorderColor #2E5A88
  ArrowColor #34506B
}
skinparam entity {
  BackgroundColor<<frontera>> #EFEFEF
  BorderColor<<frontera>> #9AA5B1
}
hide circle
title Modelo Entidad-Relacion — Modulo Compras y Cuentas por Pagar (SOLSGE)\nEsquema físico: PK (llave), FK (#), * = obligatorio

' --- entidades del módulo ---
entity "PROVEEDORES" as PROVEEDORES {
  * ID_PERSONA : NUMBER <<PK, FK-PERSONAS>>
  CODIGO_USUARIO : VARCHAR2(1000)
  ESTADO : VARCHAR2(1)
  FECHA_REGISTRO : DATE
  CATEGORIA : VARCHAR2(50)
  PLAZO_PAGO_DIAS : NUMBER
}

entity "PROVEEDOR_CONTACTOS" as PROVEEDOR_CONTACTOS {
  * ID_CONTACTO : NUMBER <<PK>>
  * ID_PROVEEDOR : NUMBER <<FK-PROVEEDORES>>
  * NOMBRE : VARCHAR2(100)
  TELEFONO : VARCHAR2(50)
  CORREO : VARCHAR2(100)
  CARGO : VARCHAR2(100)
}

entity "ORDENES_COMPRA" as ORDENES_COMPRA {
  * ID_ORDEN_COMPRA : NUMBER <<PK>>
  * ID_PROVEEDOR : NUMBER <<FK-PROVEEDORES>>
  FECHA_ORDEN : DATE
  * ESTADO : CHAR(1)
  OBSERVACION : VARCHAR2(255)
  ID_EMPLEADO : NUMBER <<FK-EMPLEADOS>>
  ID_OFICINA : NUMBER <<FK-OFICINAS>>
  TOTAL_ORDEN : NUMBER(14,2)
  ID_APROBADOR : NUMBER <<FK-EMPLEADOS>>
  FECHA_APROBACION : DATE
  MOTIVO_RECHAZO : VARCHAR2(500)
}

entity "DETALLE_ORDEN_COMPRA" as DETALLE_ORDEN_COMPRA {
  * ID_DETALLE_OC : NUMBER <<PK>>
  * ID_ORDEN_COMPRA : NUMBER <<FK-ORDENES_COMPRA>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * CANTIDAD : NUMBER(12,2)
  PRECIO_UNITARIO : NUMBER(12,2)
  TOTAL_DETALLE : NUMBER(14,2)
}

entity "RECEPCIONES_COMPRA" as RECEPCIONES_COMPRA {
  * ID_RECEPCION : NUMBER <<PK>>
  * ID_ORDEN_COMPRA : NUMBER <<FK-ORDENES_COMPRA>>
  ID_COMPROBANTE : NUMBER <<FK-COMPROBANTES_PROVEEDOR>>
  FECHA_RECEPCION : DATE
  ID_EMPLEADO : NUMBER <<FK-EMPLEADOS>>
  OBSERVACION : VARCHAR2(255)
}

entity "DETALLE_RECEPCION_COMPRA" as DETALLE_RECEPCION_COMPRA {
  * ID_DETALLE_REC : NUMBER <<PK>>
  * ID_RECEPCION : NUMBER <<FK-RECEPCIONES_COMPRA>>
  * ID_DETALLE_OC : NUMBER <<FK-DETALLE_ORDEN_COMPRA>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * CANTIDAD_RECIBIDA : NUMBER(12,2)
}

entity "COMPROBANTES_PROVEEDOR" as COMPROBANTES_PROVEEDOR {
  * ID_COMPROBANTE : NUMBER <<PK>>
  * TIPO_COMPROBANTE : CHAR(2)
  * ID_PROVEEDOR : NUMBER <<FK-PROVEEDORES>>
  FECHA_EMISION : DATE
  NRO_COMPROBANTE : VARCHAR2(50)
  NRO_TIMBRADO : VARCHAR2(20)
  FECHA_INICIO_TIMBRADO : DATE
  FECHA_FIN_TIMBRADO : DATE
  MONEDA : VARCHAR2(10)
  TIPO_CAMBIO : NUMBER(12,4)
  TOTAL_COMPROBANTE : NUMBER(12,2)
  ID_OFICINA : NUMBER <<FK-OFICINAS>>
  ID_ORDEN_COMPRA : NUMBER <<FK-ORDENES_COMPRA>>
  ID_FAC_ORIGEN : NUMBER
  OBSERVACION : VARCHAR2(255)
  * ESTADO : VARCHAR2(30)
  FORMA_PAGO : VARCHAR2(2)
  COD_MOTIVO : NUMBER(2) <<FK-MOTIVOS_NOTA_CREDITO>>
}

entity "DETALLE_COMPROBANTE_PROV" as DETALLE_COMPROBANTE_PROV {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_COMPROBANTE : NUMBER <<FK-COMPROBANTES_PROVEEDOR>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  CANTIDAD : NUMBER(12,2)
  PRECIO_UNITARIO : NUMBER(12,2)
  TOTAL : NUMBER
  ID_DETALLE_ORIGEN : NUMBER
}

entity "CUENTAS_PAGAR" as CUENTAS_PAGAR {
  * ID_CXP : NUMBER <<PK>>
  * ID_PROVEEDOR : NUMBER <<FK-PROVEEDORES>>
  * ID_COMPROBANTE : NUMBER <<FK-COMPROBANTES_PROVEEDOR>>
  TOTAL_A_PAGAR : NUMBER(12,2)
  SALDO : NUMBER(12,2)
  FECHA_REGISTRO : DATE
  ESTADO : VARCHAR2(20)
  FECHA_VENCIMIENTO : DATE
}

entity "ORDENES_PAGO" as ORDENES_PAGO {
  * ID_ORDEN_PAGO : NUMBER <<PK>>
  * ID_PROVEEDOR : NUMBER <<FK-PROVEEDORES>>
  FECHA_EMISION : DATE
  FECHA_PAGO : DATE
  TOTAL_PAGO : NUMBER
  ID_METODO_PAGO : NUMBER <<FK-METODOS_PAGO>>
  ESTADO : VARCHAR2(20)
  USUARIO : VARCHAR2(60)
  OBSERVACION : VARCHAR2(255)
  MOTIVO_ANULACION : VARCHAR2(255)
}

entity "ORDEN_PAGO_DET" as ORDEN_PAGO_DET {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_ORDEN_PAGO : NUMBER <<FK-ORDENES_PAGO>>
  * ID_CXP : NUMBER <<FK-CUENTAS_PAGAR>>
  * MONTO_APLICADO : NUMBER
}

entity "PRODUCTO_PROVEEDORES" as PRODUCTO_PROVEEDORES {
  * ID_PRODUCTO : NUMBER <<PK, FK-PRODUCTOS>>
  * ID_PERSONA : NUMBER <<PK, FK-PROVEEDORES>>
  CODIGO_REFERENCIA : VARCHAR2(100)
  * PRECIO : NUMBER
  * FECHA_INICIO : DATE <<PK>>
  FECHA_FIN : DATE
  * ESTADO : VARCHAR2(20)
  * FECHA_CREACION : DATE
  USUARIO_CREACION : VARCHAR2(100)
  FECHA_MODIFICACION : DATE
  USUARIO_MODIFICACION : VARCHAR2(100)
}

entity "PRECIO_POR_CATEGORIA" as PRECIO_POR_CATEGORIA {
  * ID_PRECIO : NUMBER <<PK>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * CATEGORIA_CLIENTE : VARCHAR2(50)
  * PRECIO : NUMBER(12,2)
  MONEDA : VARCHAR2(10)
  FECHA_VIGENCIA : DATE
  ACTIVO : CHAR(1)
}

entity "MARGEN_CATEGORIA" as MARGEN_CATEGORIA {
  * ID_MARGEN : NUMBER <<PK>>
  * ID_CATEGORIA : NUMBER <<FK-CATEGORIAS_PRODUCTOS>>
  * CATEGORIA_CLIENTE : VARCHAR2(20)
  * PORCENTAJE : NUMBER(5,2)
  * FECHA_INICIO : DATE
  FECHA_FIN : DATE
  * ESTADO : VARCHAR2(20)
  USUARIO_CREACION : VARCHAR2(100)
  * FECHA_CREACION : DATE
  USUARIO_MODIFICACION : VARCHAR2(100)
  FECHA_MODIFICACION : DATE
}

entity "AUDITORIA_PRODUCTO_PROVEEDOR" as AUDITORIA_PRODUCTO_PROVEEDOR {
  * ID_AUDITORIA : NUMBER <<PK>>
  * ID_PRODUCTO : NUMBER
  * ID_PERSONA : NUMBER
  FECHA_INICIO : DATE
  PRECIO_ANTERIOR : NUMBER
  PRECIO_NUEVO : NUMBER
  ESTADO_ANTERIOR : VARCHAR2(20)
  ESTADO_NUEVO : VARCHAR2(20)
  TIPO_OPERACION : VARCHAR2(20)
  FECHA_CAMBIO : DATE
  USUARIO_CAMBIO : VARCHAR2(100)
}

entity "CARGA_MASIVA_PP" as CARGA_MASIVA_PP {
  * ID_CARGA : NUMBER <<PK>>
  FECHA_CARGA : DATE
  USUARIO_CARGA : VARCHAR2(100)
  NOMBRE_ARCHIVO : VARCHAR2(255)
  REGISTROS_TOTALES : NUMBER
  REGISTROS_EXITOSOS : NUMBER
  REGISTROS_ERROR : NUMBER
  ESTADO_CARGA : VARCHAR2(20)
  FECHA_FINALIZACION : DATE
}

entity "DETALLE_CARGA_MASIVA_PP" as DETALLE_CARGA_MASIVA_PP {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_CARGA : NUMBER <<FK-CARGA_MASIVA_PP>>
  FILA_NUMERO : NUMBER
  ID_PRODUCTO : NUMBER
  ID_PERSONA : NUMBER
  CODIGO_REFERENCIA : VARCHAR2(100)
  PRECIO : NUMBER
  FECHA_INICIO : DATE
  FECHA_FIN : DATE
  ESTADO : VARCHAR2(20)
  ESTADO_PROCESAMIENTO : VARCHAR2(20)
  MENSAJE_ERROR : VARCHAR2(500)
}

' --- entidades frontera ---
entity "PERSONAS" as PERSONAS <<frontera>> {
  * ID_PERSONA : NUMBER <<PK>>
}

entity "OFICINAS" as OFICINAS <<frontera>> {
  * CODIGO_OFICINA : NUMBER <<PK>>
}

entity "EMPLEADOS" as EMPLEADOS <<frontera>> {
  * ID_EMPLEADO : NUMBER(38) <<PK>>
}

entity "PRODUCTOS" as PRODUCTOS <<frontera>> {
  * ID_PRODUCTO : NUMBER <<PK>>
}

entity "MOTIVOS_NOTA_CREDITO" as MOTIVOS_NOTA_CREDITO <<frontera>> {
  * COD_MOTIVO : NUMBER(2) <<PK>>
}

entity "METODOS_PAGO" as METODOS_PAGO <<frontera>> {
  * ID_METODO_PAGO : NUMBER <<PK>>
}

entity "CATEGORIAS_PRODUCTOS" as CATEGORIAS_PRODUCTOS <<frontera>> {
  * ID_CATEGORIA : NUMBER <<PK>>
}

' --- relaciones (crow's-foot desde FK reales) ---
PERSONAS ||--o{ PROVEEDORES
PROVEEDORES ||--o{ PROVEEDOR_CONTACTOS
OFICINAS ||--o{ ORDENES_COMPRA
EMPLEADOS ||--o{ ORDENES_COMPRA
PROVEEDORES ||--o{ ORDENES_COMPRA
PRODUCTOS ||--o{ DETALLE_ORDEN_COMPRA
ORDENES_COMPRA ||--o{ DETALLE_ORDEN_COMPRA
ORDENES_COMPRA ||--o{ RECEPCIONES_COMPRA
EMPLEADOS ||--o{ RECEPCIONES_COMPRA
COMPROBANTES_PROVEEDOR ||--o{ RECEPCIONES_COMPRA
DETALLE_ORDEN_COMPRA ||--o{ DETALLE_RECEPCION_COMPRA
PRODUCTOS ||--o{ DETALLE_RECEPCION_COMPRA
RECEPCIONES_COMPRA ||--o{ DETALLE_RECEPCION_COMPRA
MOTIVOS_NOTA_CREDITO ||--o{ COMPROBANTES_PROVEEDOR
OFICINAS ||--o{ COMPROBANTES_PROVEEDOR
PROVEEDORES ||--o{ COMPROBANTES_PROVEEDOR
ORDENES_COMPRA ||--o{ COMPROBANTES_PROVEEDOR
PRODUCTOS ||--o{ DETALLE_COMPROBANTE_PROV
COMPROBANTES_PROVEEDOR ||--o{ DETALLE_COMPROBANTE_PROV
COMPROBANTES_PROVEEDOR ||--o{ CUENTAS_PAGAR
PROVEEDORES ||--o{ CUENTAS_PAGAR
METODOS_PAGO ||--o{ ORDENES_PAGO
PROVEEDORES ||--o{ ORDENES_PAGO
ORDENES_PAGO ||--o{ ORDEN_PAGO_DET
CUENTAS_PAGAR ||--o{ ORDEN_PAGO_DET
PRODUCTOS ||--o{ PRODUCTO_PROVEEDORES
PROVEEDORES ||--o{ PRODUCTO_PROVEEDORES
PRODUCTOS ||--o{ PRECIO_POR_CATEGORIA
CATEGORIAS_PRODUCTOS ||--o{ MARGEN_CATEGORIA
CARGA_MASIVA_PP ||--o{ DETALLE_CARGA_MASIVA_PP
@enduml
