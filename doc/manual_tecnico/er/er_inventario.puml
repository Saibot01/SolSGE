@startuml er_inventario
!theme plain
skinparam dpi 150
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 4
skinparam linetype ortho
skinparam DefaultFontName Segoe UI
skinparam entityFontSize 12
skinparam entityAttributeFontSize 10
skinparam entity {
  BackgroundColor #FFFFFF
  BorderColor #2E5A88
  ArrowColor #34506B
}
skinparam entity {
  BackgroundColor<<frontera>> #EFEFEF
  BorderColor<<frontera>> #9AA5B1
}
hide circle
title Modelo Entidad-Relacion — Modulo Inventario (SOLSGE)\nEsquema físico: PK (llave), FK (#), * = obligatorio

' --- entidades del módulo ---
entity "PRODUCTOS" as PRODUCTOS {
  * ID_PRODUCTO : NUMBER <<PK>>
  * NOMBRE : VARCHAR2(255)
  ID_CATEGORIA : NUMBER <<FK-CATEGORIAS_PRODUCTOS>>
  ID_MARCA : NUMBER <<FK-MARCAS>>
  DESCRIPCION : VARCHAR2(500)
  MODELO : VARCHAR2(100)
  CODIGO_PROVEEDOR : VARCHAR2(50)
  ACTIVO : CHAR(1)
  ID_TIPO_IVA : NUMBER
}

entity "CATEGORIAS_PRODUCTOS" as CATEGORIAS_PRODUCTOS {
  * ID_CATEGORIA : NUMBER <<PK>>
  * NOMBRE : VARCHAR2(100)
  DESCRIPCION : VARCHAR2(255)
}

entity "MARCAS" as MARCAS {
  * ID_MARCA : NUMBER <<PK>>
  * NOMBRE : VARCHAR2(100)
}

entity "STOCK_PRODUCTO" as STOCK_PRODUCTO {
  * ID_PRODUCTO : NUMBER <<PK, FK-PRODUCTOS>>
  * ID_OFICINA : NUMBER <<PK, FK-OFICINAS>>
  CANTIDAD : NUMBER
  STOCK_MAXIMO : NUMBER(10,2)
  FECHA_CREACION : DATE
  USUARIO_CREACION : VARCHAR2(100)
  FECHA_MODIFICACION : DATE
  USUARIO_MODIFICACION : VARCHAR2(100)
  STOCK_MINIMO : NUMBER(10,2)
}

entity "MOVIMIENTOS_STOCK" as MOVIMIENTOS_STOCK {
  * ID_MOVIMIENTO : NUMBER <<PK>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  * TIPO_MOVIMIENTO : VARCHAR2(20)
  * CANTIDAD : NUMBER
  FECHA_MOVIMIENTO : DATE
  REFERENCIA : VARCHAR2(255)
  OBSERVACION : VARCHAR2(255)
  USUARIO : VARCHAR2(100)
  FECHA : DATE
  HORA : VARCHAR2(10)
}

entity "AJUSTES_STOCK" as AJUSTES_STOCK {
  * ID_AJUSTE : NUMBER <<PK>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  TIPO_AJUSTE : VARCHAR2(20)
  * CANTIDAD : NUMBER
  FECHA : DATE
  * OBSERVACION : VARCHAR2(255)
  TIPO_MOVIMIENTO : VARCHAR2(20)
  USUARIO : VARCHAR2(100)
  HORA : VARCHAR2(10)
}

entity "TRANSFERENCIAS_STOCK" as TRANSFERENCIAS_STOCK {
  * ID_TRANSFERENCIA : NUMBER <<PK>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * ID_OFICINA_ORIGEN : NUMBER <<FK-OFICINAS>>
  * ID_OFICINA_DESTINO : NUMBER <<FK-OFICINAS>>
  * CANTIDAD : NUMBER
  FECHA : DATE
  * OBSERVACION : VARCHAR2(255)
  USUARIO : VARCHAR2(100)
  HORA : VARCHAR2(10)
}

entity "INVENTARIO" as INVENTARIO {
  * ID_INVENTARIO : NUMBER <<PK>>
  * NRO_DOCUMENTO : VARCHAR2(30)
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  * FECHA_INVENTARIO : DATE
  * ESTADO : VARCHAR2(15)
  OBSERVACION : VARCHAR2(4000)
  USUARIO_CREADOR : VARCHAR2(100)
  * FECHA_CREACION : DATE
  USUARIO_ENVIO : VARCHAR2(100)
  FECHA_ENVIO : DATE
  USUARIO_APROBACION : VARCHAR2(100)
  FECHA_APROBACION : DATE
  USUARIO_POSTEO : VARCHAR2(100)
  FECHA_POSTEO : DATE
  USUARIO_RECHAZO : VARCHAR2(100)
  FECHA_RECHAZO : DATE
}

entity "INVENTARIO_DETALLE" as INVENTARIO_DETALLE {
  * ID_INVENTARIO_DETALLE : NUMBER <<PK>>
  * ID_INVENTARIO : NUMBER <<FK-INVENTARIO>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * STOCK_SISTEMA : NUMBER
  * CANTIDAD_FISICA : NUMBER
  DIFERENCIA : NUMBER
  OBSERVACION : VARCHAR2(1000)
  ID_SECTOR : NUMBER <<FK-SECTORES>>
  ID_UBICACION : NUMBER <<FK-UBICACIONES>>
  ORDEN_SECTOR : NUMBER
  ORDEN_UBICACION : NUMBER
}

entity "SECTORES" as SECTORES {
  * ID_SECTOR : NUMBER <<PK>>
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  * NOMBRE : VARCHAR2(100)
  * ORDEN : NUMBER
  ACTIVO : CHAR(1)
}

entity "UBICACIONES" as UBICACIONES {
  * ID_UBICACION : NUMBER <<PK>>
  * ID_SECTOR : NUMBER <<FK-SECTORES>>
  * CODIGO : VARCHAR2(100)
  * ORDEN : NUMBER
  ACTIVO : CHAR(1)
}

entity "PRODUCTO_UBICACION" as PRODUCTO_UBICACION {
  * ID_PRODUCTO : NUMBER <<PK, FK-PRODUCTOS>>
  * ID_OFICINA : NUMBER <<PK, FK-OFICINAS>>
  * ID_SECTOR : NUMBER <<FK-SECTORES>>
  ID_UBICACION : NUMBER <<FK-UBICACIONES>>
  * ORDEN_POSICION : NUMBER
  * FECHA_CREACION : DATE
  USUARIO_CREACION : VARCHAR2(100)
  FECHA_MODIFICACION : DATE
  USUARIO_MODIFICACION : VARCHAR2(100)
}

' --- entidades frontera ---
entity "OFICINAS" as OFICINAS <<frontera>> {
  * CODIGO_OFICINA : NUMBER <<PK>>
}

' --- relaciones (crow's-foot desde FK reales) ---
CATEGORIAS_PRODUCTOS ||--o{ PRODUCTOS
MARCAS ||--o{ PRODUCTOS
OFICINAS ||--o{ STOCK_PRODUCTO
PRODUCTOS ||--o{ STOCK_PRODUCTO
PRODUCTOS ||--o{ MOVIMIENTOS_STOCK
OFICINAS ||--o{ MOVIMIENTOS_STOCK
OFICINAS ||--o{ AJUSTES_STOCK
PRODUCTOS ||--o{ AJUSTES_STOCK
OFICINAS ||--o{ TRANSFERENCIAS_STOCK
PRODUCTOS ||--o{ TRANSFERENCIAS_STOCK
OFICINAS ||--o{ INVENTARIO
PRODUCTOS ||--o{ INVENTARIO_DETALLE
SECTORES ||--o{ INVENTARIO_DETALLE
INVENTARIO ||--o{ INVENTARIO_DETALLE
UBICACIONES ||--o{ INVENTARIO_DETALLE
OFICINAS ||--o{ SECTORES
SECTORES ||--o{ UBICACIONES
UBICACIONES ||--o{ PRODUCTO_UBICACION
OFICINAS ||--o{ PRODUCTO_UBICACION
SECTORES ||--o{ PRODUCTO_UBICACION
PRODUCTOS ||--o{ PRODUCTO_UBICACION
@enduml
