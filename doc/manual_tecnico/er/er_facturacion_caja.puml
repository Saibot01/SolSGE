@startuml er_facturacion_caja
!theme plain
skinparam dpi 150
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 4
skinparam linetype ortho
skinparam DefaultFontName Segoe UI
skinparam entityFontSize 12
skinparam entityAttributeFontSize 10
skinparam entity {
  BackgroundColor #FFFFFF
  BorderColor #2E5A88
  ArrowColor #34506B
}
skinparam entity {
  BackgroundColor<<frontera>> #EFEFEF
  BorderColor<<frontera>> #9AA5B1
}
hide circle
title Modelo Entidad-Relacion — Modulo Facturación y Caja (SOLSGE)\nEsquema físico: PK (llave), FK (#), * = obligatorio

' --- entidades del módulo ---
entity "COMPROBANTES" as COMPROBANTES {
  * ID_COMPROBANTE : NUMBER <<PK>>
  * ID_CLIENTE : NUMBER <<FK-CLIENTES>>
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  ID_ORDEN_VENTA : NUMBER <<FK-ORDENES_VENTA>>
  * TIPO_COMPROBANTE : CHAR(2)
  ID_FAC_ORIGEN : VARCHAR2(100)
  FECHA : DATE
  * TOTAL_MONEDA_LOCAL : NUMBER(12,2)
  MONEDA : VARCHAR2(10)
  TIPO_CAMBIO : NUMBER(12,6)
  TOTAL_MONEDA_ORIGEN : NUMBER(12,2)
  FORMA_PAGO : VARCHAR2(20)
  ESTADO : CHAR(1)
  OBSERVACION : VARCHAR2(255)
  ID_TALONARIO : NUMBER <<FK-TALONARIOS>>
  NRO_COMPROBANTE : VARCHAR2(20)
  ID_PLAN_CUOTA : NUMBER <<FK-PLANES_CUOTA>>
  TOTAL_EXENTA : NUMBER(12,2)
  TOTAL_GRAVADA_5 : NUMBER(12,2)
  TOTAL_GRAVADA_10 : NUMBER(12,2)
  TOTAL_IVA_5 : NUMBER(12,2)
  TOTAL_IVA_10 : NUMBER(12,2)
  TOTAL_IVA : NUMBER(12,2)
  ID_METODO_PAGO : NUMBER <<FK-METODOS_PAGO>>
  MOTIVO_ANULACION : VARCHAR2(500)
  USUARIO_SOLICITA : VARCHAR2(60)
  FECHA_SOLICITUD : DATE
  USUARIO_APRUEBA : VARCHAR2(60)
  FECHA_RESOLUCION : DATE
  MOTIVO_RECHAZO : VARCHAR2(500)
  FECHA_HORA_EMISION : TIMESTAMP
  COD_MOTIVO : NUMBER(2) <<FK-MOTIVOS_NOTA_CREDITO>>
  ID_COMPROBANTE_ORIGEN : NUMBER <<FK-COMPROBANTES>>
  INTERES_FINANCIACION : NUMBER
}

entity "DETALLE_COMPROBANTE" as DETALLE_COMPROBANTE {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_COMPROBANTE : NUMBER <<FK-COMPROBANTES>>
  * ID_PRODUCTO : NUMBER <<FK-PRODUCTOS>>
  * CANTIDAD : NUMBER
  PRECIO_UNITARIO : NUMBER(12,2)
  TOTAL_LINEA : NUMBER(12,2)
  ID_TIPO_IVA : NUMBER <<FK-TIPO_IVA>>
  MONTO_IVA : NUMBER(12,2)
  PORCENTAJE_IVA : NUMBER(5,2)
}

entity "TALONARIOS" as TALONARIOS {
  * ID_TALONARIO : NUMBER <<PK>>
  * ID_OFICINA : NUMBER <<FK-OFICINAS>>
  * TIPO_COMPROBANTE : VARCHAR2(2)
  * ESTABLECIMIENTO : VARCHAR2(3)
  * PUNTO_EXPEDICION : VARCHAR2(3)
  * NRO_INICIAL : NUMBER
  * NRO_FINAL : NUMBER
  * NRO_ACTUAL : NUMBER
  * TIMBRADO : VARCHAR2(20)
  * FECHA_INICIO : DATE
  * FECHA_FIN : DATE
  ACTIVO : CHAR(1)
  * ID_CAJA_CONF : NUMBER <<FK-CAJA_CONF>>
}

entity "PLANES_CUOTA" as PLANES_CUOTA {
  CUOTAS : NUMBER
  DESCRIPCION : VARCHAR2(50)
  TASA_INTERES_PORCENTAJE : NUMBER(5,2)
  ACTIVO : CHAR(1)
  * ID_PLAN_CUOTA : NUMBER <<PK>>
}

entity "CUENTAS_COBRAR" as CUENTAS_COBRAR {
  * ID_CXC : NUMBER <<PK>>
  * ID_PERSONA : NUMBER <<FK-PERSONAS>>
  * ID_COMPROBANTE : NUMBER
  TOTAL_A_PAGAR : NUMBER(12,2)
  SALDO : NUMBER(12,2)
  FECHA_REGISTRO : DATE
  ESTADO : VARCHAR2(20)
}

entity "CUENTAS_COBRAR_DET" as CUENTAS_COBRAR_DET {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_CXC : NUMBER <<FK-CUENTAS_COBRAR>>
  * NRO_CUOTA : NUMBER
  * FECHA_VENCIMIENTO : DATE
  * MONTO_CUOTA : NUMBER(12,2)
  ESTADO : VARCHAR2(20)
}

entity "CAJA_CONF" as CAJA_CONF {
  * ID_CAJA_CONF : NUMBER <<PK>>
  * DESCRIPCION : VARCHAR2(50)
  ESTADO : CHAR(1)
  ID_OFICINA : NUMBER <<FK-OFICINAS>>
  PUNTO_EXPEDICION : VARCHAR2(3)
}

entity "CAJAS" as CAJAS {
  * ID_CAJA : NUMBER <<PK>>
  * ID_EMPLEADO : NUMBER <<FK-EMPLEADOS>>
  ESTADO : CHAR(1)
  FEC_APERTURA : TIMESTAMP
  FEC_CIERRE : TIMESTAMP
  USU_APERTURA : VARCHAR2(35)
  USU_CIERRE : VARCHAR2(35)
  ID_CAJA_CONF : NUMBER <<FK-CAJA_CONF>>
  ID_OFICINA : NUMBER <<FK-OFICINAS>>
  OBSERVACION : VARCHAR2(255)
}

entity "CAJA_MONEDAS" as CAJA_MONEDAS {
  * ID_CAJA : NUMBER <<PK, FK-CAJAS>>
  * MONEDA : VARCHAR2(10) <<PK, FK-MONEDAS>>
  MONTO_APERTURA : NUMBER(12,2)
  MONTO_CIERRE : NUMBER(12,2)
  MONTO_DECLARADO : NUMBER
  MONTO_DIFERENCIA : NUMBER
  MONTO_CIERRE_PREV : NUMBER
}

entity "MOVIMIENTOS_CAJA" as MOVIMIENTOS_CAJA {
  * ID_MOVIMIENTO : NUMBER <<PK>>
  * ID_CLIENTE : NUMBER <<FK-CLIENTES>>
  * ID_CAJA : NUMBER <<FK-CAJAS>>
  FECHA : TIMESTAMP
  * TOTAL_MONEDA_LOCAL : NUMBER(12,2)
  MONEDA : VARCHAR2(10)
  TIPO_CAMBIO : NUMBER(12,6)
  TOTAL_MONEDA_ORIGEN : NUMBER(12,2)
  ESTADO : CHAR(1)
  OBSERVACION : VARCHAR2(255)
  * TIPO : VARCHAR2(20)
  ID_COMPROBANTE : NUMBER <<FK-COMPROBANTES>>
  USUARIO : VARCHAR2(60)
  NRO_RECIBO : VARCHAR2(20)
  ID_TALONARIO_RECIBO : NUMBER <<FK-TALONARIOS>>
  FECHA_EMISION_RECIBO : DATE
  ID_CUENTA_COBRAR_DET : NUMBER <<FK-CUENTAS_COBRAR_DET>>
  ID_MOVIMIENTO_REVERSADO : NUMBER <<FK-MOVIMIENTOS_CAJA>>
}

entity "DETALLE_MOVIMIENTO_CAJA" as DETALLE_MOVIMIENTO_CAJA {
  * ID_DETALLE : NUMBER <<PK>>
  * ID_MOVIMIENTO : NUMBER <<FK-MOVIMIENTOS_CAJA>>
  * ID_FORMA_PAGO : NUMBER <<FK-FORMAS_PAGO>>
  * MONTO_LOCAL : NUMBER(12,2)
  MONTO_ORIGEN : NUMBER(12,2)
  MONEDA : VARCHAR2(10)
  TIPO_CAMBIO : NUMBER(12,6)
  NRO_REFERENCIA : VARCHAR2(50)
  NRO_TARJETA : VARCHAR2(50)
  ID_METODO_PAGO : NUMBER <<FK-METODOS_PAGO>>
}

entity "FORMAS_PAGO" as FORMAS_PAGO {
  * ID_FORMA_PAGO : NUMBER <<PK>>
  * DESCRIPCION : VARCHAR2(50)
  REQUIERE_REFERENCIA : CHAR(1)
  ACTIVO : CHAR(1)
}

entity "METODOS_PAGO" as METODOS_PAGO {
  * ID_METODO_PAGO : NUMBER <<PK>>
  * NOMBRE : VARCHAR2(50)
  DESCRIPCION : VARCHAR2(100)
}

entity "MONEDAS" as MONEDAS {
  * CODIGO_MONEDA : VARCHAR2(10) <<PK>>
  DESCRIPCION : VARCHAR2(50)
  ES_LOCAL : CHAR(1)
}

entity "MOTIVOS_NOTA_CREDITO" as MOTIVOS_NOTA_CREDITO {
  * COD_MOTIVO : NUMBER(2) <<PK>>
  * DESCRIPCION : VARCHAR2(100)
  * ACTIVO : CHAR(1)
}

entity "SOLICITUDES_NOTA_CREDITO" as SOLICITUDES_NOTA_CREDITO {
  * ID_SOLICITUD_NC : NUMBER <<PK>>
  * ID_COMPROBANTE_ORIGEN : NUMBER <<FK-COMPROBANTES>>
  * COD_MOTIVO : NUMBER(2) <<FK-MOTIVOS_NOTA_CREDITO>>
  * TIPO_NC : CHAR(1)
  * DEVUELVE_STOCK : CHAR(1)
  OBSERVACION : VARCHAR2(500)
  * ESTADO : CHAR(1)
  * USUARIO_SOLICITA : VARCHAR2(60)
  * FECHA_SOLICITUD : DATE
  USUARIO_APRUEBA : VARCHAR2(60)
  FECHA_RESOLUCION : DATE
  MOTIVO_RECHAZO : VARCHAR2(500)
  ID_NC_GENERADA : NUMBER <<FK-COMPROBANTES>>
}

entity "SOLICITUD_NC_DETALLE" as SOLICITUD_NC_DETALLE {
  * ID_SOL_NC_DET : NUMBER <<PK>>
  * ID_SOLICITUD_NC : NUMBER <<FK-SOLICITUDES_NOTA_CREDITO>>
  * ID_DETALLE_ORIGEN : NUMBER <<FK-DETALLE_COMPROBANTE>>
  * ID_PRODUCTO : NUMBER
  * CANTIDAD : NUMBER
  PRECIO_UNITARIO : NUMBER(12,2)
  PORCENTAJE_IVA : NUMBER(5,2)
}

entity "SOLICITUDES_REVERSO_COBRO" as SOLICITUDES_REVERSO_COBRO {
  * ID_SOLICITUD_RC : NUMBER <<PK>>
  * ID_MOVIMIENTO : NUMBER <<FK-MOVIMIENTOS_CAJA>>
  * MOTIVO : VARCHAR2(500)
  * ESTADO : CHAR(1)
  * USUARIO_SOLICITA : VARCHAR2(60)
  * FECHA_SOLICITUD : DATE
  USUARIO_APRUEBA : VARCHAR2(60)
  FECHA_RESOLUCION : DATE
  MOTIVO_RECHAZO : VARCHAR2(500)
  ID_MOVIMIENTO_EGRESO : NUMBER <<FK-MOVIMIENTOS_CAJA>>
}

' --- entidades frontera ---
entity "CLIENTES" as CLIENTES <<frontera>> {
  * ID_PERSONA : NUMBER <<PK>>
}

entity "ORDENES_VENTA" as ORDENES_VENTA <<frontera>> {
  * ID_ORDEN : NUMBER <<PK>>
}

entity "OFICINAS" as OFICINAS <<frontera>> {
  * CODIGO_OFICINA : NUMBER <<PK>>
}

entity "PRODUCTOS" as PRODUCTOS <<frontera>> {
  * ID_PRODUCTO : NUMBER <<PK>>
}

entity "TIPO_IVA" as TIPO_IVA <<frontera>> {
  * ID_TIPO_IVA : NUMBER <<PK>>
}

entity "PERSONAS" as PERSONAS <<frontera>> {
  * ID_PERSONA : NUMBER <<PK>>
}

entity "EMPLEADOS" as EMPLEADOS <<frontera>> {
  * ID_EMPLEADO : NUMBER(38) <<PK>>
}

' --- relaciones (crow's-foot desde FK reales) ---
CLIENTES ||--o{ COMPROBANTES
MOTIVOS_NOTA_CREDITO ||--o{ COMPROBANTES
ORDENES_VENTA ||--o{ COMPROBANTES
METODOS_PAGO ||--o{ COMPROBANTES
TALONARIOS ||--o{ COMPROBANTES
OFICINAS ||--o{ COMPROBANTES
PLANES_CUOTA ||--o{ COMPROBANTES
COMPROBANTES ||--o{ COMPROBANTES : (auto-referencia)
PRODUCTOS ||--o{ DETALLE_COMPROBANTE
TIPO_IVA ||--o{ DETALLE_COMPROBANTE
COMPROBANTES ||--o{ DETALLE_COMPROBANTE
CAJA_CONF ||--o{ TALONARIOS
OFICINAS ||--o{ TALONARIOS
PERSONAS ||--o{ CUENTAS_COBRAR
CUENTAS_COBRAR ||--o{ CUENTAS_COBRAR_DET
OFICINAS ||--o{ CAJA_CONF
EMPLEADOS ||--o{ CAJAS
OFICINAS ||--o{ CAJAS
CAJA_CONF ||--o{ CAJAS
MONEDAS ||--o{ CAJA_MONEDAS
CAJAS ||--o{ CAJA_MONEDAS
MOVIMIENTOS_CAJA ||--o{ MOVIMIENTOS_CAJA : (auto-referencia)
CAJAS ||--o{ MOVIMIENTOS_CAJA
COMPROBANTES ||--o{ MOVIMIENTOS_CAJA
CUENTAS_COBRAR_DET ||--o{ MOVIMIENTOS_CAJA
CLIENTES ||--o{ MOVIMIENTOS_CAJA
TALONARIOS ||--o{ MOVIMIENTOS_CAJA
METODOS_PAGO ||--o{ DETALLE_MOVIMIENTO_CAJA
FORMAS_PAGO ||--o{ DETALLE_MOVIMIENTO_CAJA
MOVIMIENTOS_CAJA ||--o{ DETALLE_MOVIMIENTO_CAJA
COMPROBANTES ||--o{ SOLICITUDES_NOTA_CREDITO
MOTIVOS_NOTA_CREDITO ||--o{ SOLICITUDES_NOTA_CREDITO
DETALLE_COMPROBANTE ||--o{ SOLICITUD_NC_DETALLE
SOLICITUDES_NOTA_CREDITO ||--o{ SOLICITUD_NC_DETALLE
MOVIMIENTOS_CAJA ||--o{ SOLICITUDES_REVERSO_COBRO
@enduml
