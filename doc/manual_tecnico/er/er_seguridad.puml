@startuml er_seguridad
!theme plain
skinparam dpi 150
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 4
skinparam linetype ortho
skinparam DefaultFontName Segoe UI
skinparam entityFontSize 12
skinparam entityAttributeFontSize 10
skinparam entity {
  BackgroundColor #FFFFFF
  BorderColor #2E5A88
  ArrowColor #34506B
}
skinparam entity {
  BackgroundColor<<frontera>> #EFEFEF
  BorderColor<<frontera>> #9AA5B1
}
hide circle
title Modelo Entidad-Relacion — Modulo Seguridad y Personas (SOLSGE)\nEsquema físico: PK (llave), FK (#), * = obligatorio

' --- entidades del módulo ---
entity "PERSONAS" as PERSONAS {
  * ID_PERSONA : NUMBER <<PK>>
  * NRO_DOCUMENTO : VARCHAR2(20)
  * TIPO_DOCUMENTO : VARCHAR2(20)
  FECHA_VENCIMIENTO : DATE
  TIPO_PERSONA : VARCHAR2(20)
  SEXO : CHAR(1)
  * PRIMER_NOMBRE : VARCHAR2(50)
  SEGUNDO_NOMBRE : VARCHAR2(50)
  * PRIMER_APELLIDO : VARCHAR2(50)
  SEGUNDO_APELLIDO : VARCHAR2(50)
  ESTADO_CIVIL : VARCHAR2(20)
  CORREO : VARCHAR2(100)
  FECHA_NACIMIENTO : DATE
  * FECHA_REGISTRO : DATE
}

entity "EMPLEADOS" as EMPLEADOS {
  * ID_EMPLEADO : NUMBER(38) <<PK>>
  ID_PERSONA : NUMBER <<FK-PERSONAS>>
  NOMBRE : VARCHAR2(255)
  FECHA_ALTA : DATE
  CARGO : VARCHAR2(255)
  CONTRASEÑA : VARCHAR2(2000)
  CODIGO_USUARIO : VARCHAR2(1000)
  CODIGO_VERIFICACION : VARCHAR2(255)
  CORREO : VARCHAR2(1000)
  SALT_CONTRASENA : VARCHAR2(32)
  * CONTRASENA_TEMP : VARCHAR2(1)
  TOKEN_RESET : VARCHAR2(64)
  TOKEN_EXPIRACION : TIMESTAMP
  * ACTIVO : VARCHAR2(1)
  * INTENTOS_FALLIDOS : NUMBER(3)
}

entity "EMPLEADOS_ROLES" as EMPLEADOS_ROLES {
  * ID_EMPLEADO_ROL : NUMBER <<PK>>
  * ID_EMPLEADO : NUMBER <<FK-EMPLEADOS>>
  * ID_ROL : NUMBER <<FK-ROLES>>
  * FECHA_ASIGNACION : DATE
}

entity "ROLES" as ROLES {
  * ID_ROL : NUMBER <<PK>>
  * DESCRIPCION : VARCHAR2(255)
  * NOMBRE_ROL : VARCHAR2(255)
}

entity "PRIVILEGIOS" as PRIVILEGIOS {
  * ID_PRIV : NUMBER <<PK>>
  * CODIGO : VARCHAR2(60)
  * NOMBRE : VARCHAR2(120)
  DESCRIPCION : VARCHAR2(4000)
  ACTIVO : CHAR(1)
}

entity "ROLES_PRIVILEGIOS" as ROLES_PRIVILEGIOS {
  * ID_ROL : NUMBER <<PK, FK-ROLES>>
  * ID_PRIV : NUMBER <<PK, FK-PRIVILEGIOS>>
}

entity "RECURSOS" as RECURSOS {
  * ID_RECURSO : NUMBER <<PK>>
  * APP_ID : NUMBER
  * PAGE_ID : NUMBER
  COMPONENT_STATIC_ID : VARCHAR2(200)
  * ID_PRIV_REQUERIDO : NUMBER <<FK-PRIVILEGIOS>>
  ACTIVO : CHAR(1)
}

entity "CLIENTES" as CLIENTES {
  * ID_PERSONA : NUMBER <<PK, FK-PERSONAS>>
  CODIGO_USUARIO : VARCHAR2(1000)
  ESTADO : VARCHAR2(50)
  * FECHA_REGISTRO : DATE
  CATEGORIA_CLIENTE : VARCHAR2(50)
}

entity "DIRECCIONES" as DIRECCIONES {
  ID_PERSONA : NUMBER <<FK-PERSONAS>>
  DESCRIPCION : VARCHAR2(255)
  CALLE_PRINCIPAL : VARCHAR2(255)
  CALLE_SECUNDARIA : VARCHAR2(255)
  ID_PAIS : NUMBER <<FK-PAISES>>
  CODIGO_CIUDAD : NUMBER <<FK-CIUDADES>>
  CODIGO_DEPARTAMENTO : NUMBER <<FK-DEPARTAMENTOS>>
  NRO_CASA : VARCHAR2(50)
  CODIGO_POSTAL : VARCHAR2(50)
  * ID_DIRECCION : NUMBER <<PK>>
  TIPO : VARCHAR2(50)
}

entity "TELEFONOS" as TELEFONOS {
  ID_PERSONA : NUMBER <<FK-PERSONAS>>
  TIPO : VARCHAR2(50)
  NRO_TELEFONO : VARCHAR2(50)
}

entity "DOCUMENTOS" as DOCUMENTOS {
  * ID_DOCUMENTO : NUMBER <<PK>>
  * DESCRIPCION : VARCHAR2(255)
  TIPO_DOCUMENTO : VARCHAR2(255)
}

' --- entidades frontera ---
entity "DEPARTAMENTOS" as DEPARTAMENTOS <<frontera>> {
  * CODIGO_DEPARTAMENTO : NUMBER <<PK>>
}

entity "CIUDADES" as CIUDADES <<frontera>> {
  * CODIGO_CIUDAD : NUMBER <<PK>>
}

entity "PAISES" as PAISES <<frontera>> {
  * ID_PAIS : NUMBER <<PK>>
}

' --- relaciones (crow's-foot desde FK reales) ---
PERSONAS ||--o{ EMPLEADOS
EMPLEADOS ||--o{ EMPLEADOS_ROLES
ROLES ||--o{ EMPLEADOS_ROLES
PRIVILEGIOS ||--o{ ROLES_PRIVILEGIOS
ROLES ||--o{ ROLES_PRIVILEGIOS
PRIVILEGIOS ||--o{ RECURSOS
PERSONAS ||--o{ CLIENTES
DEPARTAMENTOS ||--o{ DIRECCIONES
CIUDADES ||--o{ DIRECCIONES
PERSONAS ||--o{ DIRECCIONES
PAISES ||--o{ DIRECCIONES
PERSONAS ||--o{ TELEFONOS
@enduml
